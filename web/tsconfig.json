    "@tsconfig/vite-react/tsconfig.json", // https://www.npmjs.com/package/@tsconfig/vite-react
    "../tsconfig.base.json"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "@hidess/shared": ["../shared/src/index.ts"]
    },
    "types": ["vite/client"]
