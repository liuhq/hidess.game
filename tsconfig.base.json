{
  "extends": "@tsconfig/node-ts/tsconfig.json", // https://www.npmjs.com/package/@tsconfig/node-ts
  "compilerOptions": {
    "incremental": true,
    "skipLibCheck": true,

    "strict": true,
    "allowImportingTsExtensions": true,

    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
